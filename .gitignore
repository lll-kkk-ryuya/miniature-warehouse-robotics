# Claude Code - local only
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.lock
CLAUDE.local.md

# Environment / secrets（実体 .env はコミット禁止・.env.example のみ追跡）
.env
.env.local
**/.env
config/**/.env
deploy/**/.env
deploy/**/secrets/
!**/.env.example

# Secrets
*.pem
*.key

# macOS
.DS_Store
**/.DS_Store

# ROS 2 colcon 生成物 (doc16 §8)
ws/build/
ws/install/
ws/log/

# Python
__pycache__/
*.pyc
*.egg-info/
*.egg-info
build/
dist/

# Python tooling (Ruff / pytest / coverage / venv)
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.venv/
.venv-*/

# Claude Code worktrees (parallel sessions)
.claude/worktrees/

# Playwright (web E2E)
web/e2e/node_modules/
web/e2e/playwright-report/
web/e2e/test-results/

# PlatformIO (ESP32 firmware)
firmware/.pio/

# Run artifacts: out/runs/<run_id>/{manifest.yaml,effective_composition.json}
# (docs/productization/09-run-manifest-and-plugin-composition.md:48 — run outputs, never committed)
out/runs/
