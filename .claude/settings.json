{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "Read(docs/**)",
      "Read(src/**)",
      "Read(config/**)",
      "Bash(colcon build *)",
      "Bash(colcon test *)",
      "Bash(ros2 launch *)",
      "Bash(ros2 topic *)",
      "Bash(ros2 param *)",
      "Bash(python3 -m pytest *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(secrets/**)",
      "Bash(rm -rf *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
