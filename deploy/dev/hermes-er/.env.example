# Dedicated LEAN ER Hermes gateway — secrets (copy to the instance's HERMES_HOME/.env).
# NEVER commit real values. run-er-hermes.sh generates this from your exported GOOGLE_API_KEY.
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1          # loopback only (safety.md)
API_SERVER_PORT=8643               # NOT 8642 — keep the personal ~/.hermes gateway untouched
API_SERVER_KEY=                    # openssl rand -hex 32  (Bridge -> gateway bearer token)
GOOGLE_API_KEY=                    # Gemini key (provider: google). GEMINI_API_KEY also accepted.
# Optional out-of-band tracing (enable the plugin first; see config.lean.yaml):
# HERMES_LANGFUSE_PUBLIC_KEY=
# HERMES_LANGFUSE_SECRET_KEY=
# HERMES_LANGFUSE_BASE_URL=https://cloud.langfuse.com   # NOTE: *_BASE_URL, not LANGFUSE_HOST
