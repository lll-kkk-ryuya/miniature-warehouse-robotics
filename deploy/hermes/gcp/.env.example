# =============================================================================
# Hermes Gateway .env テンプレート — GCP Slack Gateway (minicar bot)
# =============================================================================
# 実ファイルは VM 上の ~/.hermes/.env に置く。**絶対にコミットしない**
# (.gitignore で deploy/**/.env と *.key を無視済み。safety.md 準拠)
#
# このテンプレートは GCP e2-micro 上で動く Slack 連携用 Hermes Gateway
# (bot 名: minicar) が実際に参照する変数名に対応する。
# Jetson 実機側 (Warehouse MCP / ROS 連携) の .env は doc 13 §3.1 を参照。
# -----------------------------------------------------------------------------

# ── Gateway API Server ───────────────────────────────────────────────────────
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1          # loopback 固定。外部公開しない (safety.md)
API_SERVER_PORT=8642
API_SERVER_KEY=                    # openssl rand -hex 32 で生成して貼る

# ── アクセス制御 ─────────────────────────────────────────────────────────────
GATEWAY_ALLOW_ALL_USERS=false      # 全ユーザー許可は本番では false 推奨
SLACK_ALLOWED_USERS=               # 許可する Slack user_id をカンマ区切り

# ── Slack 連携 (Socket Mode) ─────────────────────────────────────────────────
SLACK_APP_TOKEN=                   # xapp-... (Socket Mode app-level token)
SLACK_BOT_TOKEN=                   # xoxb-... (Bot User OAuth token)

# ── GitHub MCP (リポジトリをライブ参照する) ──────────────────────────────────
# bot は @modelcontextprotocol/server-github 経由で main を直接読む。
# repo:read 権限を持つ fine-grained PAT を推奨。
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# config.yaml の model.provider に合わせて必要なキーを設定。
# 現行 Gateway は google (gemini-2.5-flash) を使用。
GOOGLE_API_KEY=
# Phase 4 の 4 社比較で追加する場合:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=

# ── Langfuse (任意 / Phase 4 比較トレース) ───────────────────────────────────
# 内蔵 plugin は opt-in: `pip install langfuse` + `hermes plugins enable observability/langfuse`
# の後、下記キーで有効化（doc08 §Langfuse）。fail-open・background 送信で本線を止めない。
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # plugin が読むのは *_BASE_URL（LANGFUSE_HOST ではない）。HERMES_LANGFUSE_BASE_URL 優先

# ── ロギング (任意) ──────────────────────────────────────────────────────────
LOG_LEVEL=info                     # debug | info | warning | error
