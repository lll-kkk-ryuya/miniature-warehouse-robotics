# =============================================================================
# Lean ER (Gemini Robotics-ER) Hermes gateway — secrets template (PLACEHOLDERS ONLY)
# =============================================================================
# Copy this to the ISOLATED HERMES_HOME for the FORK ER gateway and fill in real
# values there. Default isolated home: ~/.hermes-mwr-er-fork (NEVER ~/.hermes; also
# DISTINCT from the unforked run-er-hermes.sh home ~/.hermes-mwr-er-lean, so the fork
# never inherits the unforked's 8643 port).
#
#   cp .env.example ~/.hermes-mwr-er-fork/.env   # then edit the copy
#
# RULES:
# - NEVER commit a filled-in .env (config/**/.env and **/.env are gitignored).
# - This file holds placeholders only — never real keys.
# - run-er-gateway.sh SOURCES $HERMES_HOME/.env and never echoes these values.
# - dev / stg / prod use SEPARATE keys (see .claude/rules/environments.md).
#
# Hermes reads these from env at gateway startup (gateway/config.py:1490-1506,
# gateway/platforms/api_server.py:691-696). The gateway also auto-loads
# $HERMES_HOME/.env (gateway/run.py:851-852); run-er-gateway.sh additionally
# sources it so the host-side health/probe curls can authenticate.
# =============================================================================

# Native Gemini provider key for the ER model (gemini-robotics-er-1.6-preview).
# provider "google" in config.yaml consumes GOOGLE_API_KEY (or GEMINI_API_KEY).
GOOGLE_API_KEY=

# Bearer token the OpenAI-compatible API server requires on /v1/* requests.
# The LLM Bridge sends "Authorization: Bearer <API_SERVER_KEY>". Must match.
API_SERVER_KEY=

# API server bind address + port. Loopback only by default (do NOT expose ER
# on a routable interface without auth review). Port 8644 keeps the FORK ER gateway
# off the personal daily-driver (8642), the Mode-A Hermes (8642), AND the unforked
# fallback run-er-hermes.sh (8643). run-er-gateway.sh's ensure_env_port() re-pins this
# to 8644 on start, so a stale value can't make the fork bind the unforked's port.
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8644
