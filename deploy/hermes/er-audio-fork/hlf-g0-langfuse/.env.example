# =============================================================================
# .env.example — placeholders ONLY for the HLF-G0 Langfuse-plugin probe.
# =============================================================================
# Real values live in HERMES_HOME/.env (the gateway auto-loads it). Scripts SOURCE
# it; they NEVER echo/print the values. Commit ONLY this .example (placeholders).
# The real `.env` is gitignored (deploy/**/.env, **/.env — see repo .gitignore).
#
# These are the env vars the Hermes built-in Langfuse plugin reads (GROUNDED):
#   ~/.hermes/hermes-agent/plugins/observability/langfuse/ (clone v0.15.1).
# Put them in the ISOLATED gateway's HERMES_HOME/.env (default ~/.hermes-mwr-er-lean),
# NEVER in personal ~/.hermes. The `langfuse` python package must be supplied via
# `pip install --target <ISOLATED_DIR>` + PYTHONPATH (never the Hermes venv).
# -----------------------------------------------------------------------------

# Langfuse project keys (the plugin authenticates with these).
HERMES_LANGFUSE_PUBLIC_KEY=
HERMES_LANGFUSE_SECRET_KEY=

# Langfuse API base URL (self-host or cloud region host).
HERMES_LANGFUSE_BASE_URL=

# Optional plugin knobs (safe to leave blank for the probe).
HERMES_LANGFUSE_ENV=
HERMES_LANGFUSE_SAMPLE_RATE=
HERMES_LANGFUSE_RELEASE=
HERMES_LANGFUSE_DEBUG=
HERMES_LANGFUSE_MAX_CHARS=
