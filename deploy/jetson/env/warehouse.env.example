# warehouse.env — environment for the Jetson (prod) systemd units.
#
# Install the REAL file at /etc/warehouse/warehouse.env (loaded by every
# warehouse-*.service via EnvironmentFile). This file holds NO secrets — API
# keys / tokens / WiFi passwords live in config/prod/.env and ~/.hermes/.env
# (doc19 §4, .claude/rules/safety.md). Copy this template and adjust paths.
#
#   sudo install -D -m 0644 deploy/jetson/env/warehouse.env.example \
#        /etc/warehouse/warehouse.env
#
# Source of truth: docs/architecture/19-environments-and-config.md (prod row),
# ws/src/warehouse_interfaces/warehouse_interfaces/paths.py (runtime/config dirs).

# Environment selector. prod => runtime dir /run/warehouse (paths.py:22-30),
# real robots, GCP Hermes (doc19:18,20). Never silently default to dev on the
# Jetson — set it explicitly here.
WAREHOUSE_ENV=prod

# ROS 2 distribution sourced by ros-exec.sh (doc02:151 — ROS 2 Jazzy on Jetson).
ROS_DISTRO=jazzy

# Repo clone root (doc19:94 — Jetson checks out a release git tag) and the
# colcon workspace inside it. ros-exec.sh sources ${WAREHOUSE_WS}/install/setup.bash.
WAREHOUSE_REPO=/opt/warehouse
WAREHOUSE_WS=/opt/warehouse/ws

# Warehouse config dir (base + prod overlay; paths.py:54-57). load_config() reads
# ${WAREHOUSE_CONFIG_DIR}/warehouse.base.yaml then prod/warehouse.yaml.
WAREHOUSE_CONFIG_DIR=/opt/warehouse/config

# micro-ROS Agent transport: WiFi/UDP to the minicars (doc02:71 "WiFi通信").
# 8888 is the micro-ROS default UDP port.
MICROROS_PORT=8888

# Nav2 bring-up args passed to warehouse_bringup/launch/bringup.launch.py (the
# composition lands with #75; these args are inert until #75 merges).
# traffic_mode: none|simple|open-rmf (open-rmf = Mode C disables VirtualScan, doc11a:317).
# IMPORTANT: prod policy is Mode C — keep this in sync with the warehouse config
# single source config/prod/warehouse.yaml:13 (traffic_mode: open-rmf, doc19:54).
# TODO(#75/nav-traffic): have bringup.launch.py read traffic_mode from the warehouse
# config so this duplicate CLI override can be dropped (single source of truth).
WAREHOUSE_TRAFFIC_MODE=open-rmf
# TODO(Phase 1): set to the prod map produced by SLAM Toolbox on the real diorama.
WAREHOUSE_MAP=/opt/warehouse/maps/warehouse.yaml
