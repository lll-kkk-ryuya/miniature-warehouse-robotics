[Unit]
# Nav2 stack — composes the per-bot Nav2 + twist_mux + VirtualScan via the
# top-level bring-up (warehouse_bringup/launch/bringup.launch.py; itself Includes
# nav2_bringup.launch.py). NOTE: that composition lands with #75 — until #75
# merges, bringup.launch.py is an empty placeholder and the launch args below are
# inert no-ops (Depends on #75).
# This unit MOVES the real robots, so it BindsTo= the Emergency Guardian:
# BindsTo + After guarantees Nav2 is never active without Layer 1 safety active
# and — unlike Requires= — also stops Nav2 when the guardian terminates
# UNEXPECTEDLY (crash / clean exit), not only on an explicit stop (systemd.unit(5);
# doc12:80-84, .claude/rules/safety.md).
Description=Warehouse Nav2 bring-up (per-bot Nav2 + twist_mux + VirtualScan)
Documentation=https://github.com/lll-kkk-ryuya/miniature-warehouse-robotics/blob/main/docs/setup/jetson-deploy.md
After=warehouse-safety.service
BindsTo=warehouse-safety.service
PartOf=warehouse.target

[Service]
Type=simple
EnvironmentFile=-/etc/warehouse/warehouse.env
User=warehouse
Group=warehouse
# RPLiDAR A1 over USB (doc02:180); dialout = serial-access group. use_sim_time:=false
# on real hardware; traffic_mode / map from the env file (see warehouse.env.example).
SupplementaryGroups=dialout
ExecStart=/opt/warehouse/deploy/jetson/bin/ros-exec.sh ros2 launch warehouse_bringup bringup.launch.py use_sim_time:=false traffic_mode:=${WAREHOUSE_TRAFFIC_MODE} map:=${WAREHOUSE_MAP}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=warehouse.target
