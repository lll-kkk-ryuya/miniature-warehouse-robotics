# Hermes Gateway environment variables (template)
# DO NOT COMMIT the real .env file. Add `.env` to .gitignore.

# ---- LLM providers (4-way comparison) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# ---- Slack adapter (Socket Mode, outbound WebSocket only) ----
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ---- Hermes Gateway HTTP API auth ----
# Used later by LLM Bridge Node (on Jetson) to POST /v1/chat/completions
HERMES_API_SERVER_KEY=

# ---- Optional: Langfuse (Phase 4 comparison metrics) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
