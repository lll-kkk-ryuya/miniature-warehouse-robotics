# stg secrets テンプレ。コピーして config/stg/.env を作る（.env は gitignore・コミット厳禁）。
# dev とは別キーを使う（環境混在・課金事故の防止）。

# Hermes Gateway 認証（Bridge は HERMES_API_KEY/API_SERVER_KEY を読む。llm_bridge.py:70）
API_SERVER_KEY=

# LLM プロバイダ鍵は Hermes VM(~/.hermes/.env)に置く。Gemini は GOOGLE_API_KEY。
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Langfuse: Bridge=LANGFUSE_*（標準SDK名） / Orchestrator=HERMES_LANGFUSE_*。両方に同値。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
HERMES_LANGFUSE_PUBLIC_KEY=
HERMES_LANGFUSE_SECRET_KEY=
HERMES_LANGFUSE_HOST=https://cloud.langfuse.com

# RunPod（Isaac Sim 統合する場合）
RUNPOD_API_KEY=
