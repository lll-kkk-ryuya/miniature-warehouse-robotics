# dev secrets テンプレ。コピーして config/dev/.env を作る（.env は gitignore・コミット厳禁）。
# .claude/rules/safety.md: APIキー/認証情報/WiFiパスワードはコミットしない。

# ── Hermes Gateway 認証（Bridge → Gateway）──
# Bridge は HERMES_API_KEY か API_SERVER_KEY を読む（warehouse_llm_bridge/.../llm_bridge.py:70）。
# Hermes VM 側 ~/.hermes/.env の API_SERVER_KEY と同一値にする（deploy/hermes/gcp/.env.example）。
API_SERVER_KEY=

# ── LLM プロバイダ鍵 ──
# LLM を実際に叩くのは Hermes Gateway。これらは Hermes VM の ~/.hermes/.env に置く。
# Bridge は Hermes 経由で呼ぶため通常この config 側には不要（ローカル Hermes を使う場合のみ）。
# Gemini は GOOGLE_API_KEY（Hermes が読む名前。GOOGLE_AI_API_KEY は誰も読まない）。
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# ── Langfuse（観測。doc13 / project_langfuse）──
# Bridge は trace を所有し langfuse SDK 標準名 LANGFUSE_* を読む（tracing.py / hermes_client.py）。
# Orchestrator(KPI sink) は HERMES_LANGFUSE_* を読む（langfuse_sink.py:43-44）。両方に同一値を入れる。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
HERMES_LANGFUSE_PUBLIC_KEY=
HERMES_LANGFUSE_SECRET_KEY=
HERMES_LANGFUSE_HOST=https://cloud.langfuse.com

# WiFi（micro-ROS。実機接続する場合のみ）
ROBOT_WIFI_SSID=
ROBOT_WIFI_PASSWORD=
