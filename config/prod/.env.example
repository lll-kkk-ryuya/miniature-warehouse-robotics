# prod secrets テンプレ。コピーして config/prod/.env を作る（.env は gitignore・コミット厳禁）。
# ⚠️ 本番キー。dev/stg とは必ず別キー。本番デモ前に Emergency/速度上限テスト通過を確認。

# Hermes Gateway 認証（Bridge は HERMES_API_KEY/API_SERVER_KEY を読む。llm_bridge.py:70）
API_SERVER_KEY=

# LLM プロバイダ鍵は Hermes VM(~/.hermes/.env)に置く。Gemini は GOOGLE_API_KEY。
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Langfuse: Bridge=LANGFUSE_*（標準SDK名） / Orchestrator=HERMES_LANGFUSE_*。両方に同値。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
HERMES_LANGFUSE_PUBLIC_KEY=
HERMES_LANGFUSE_SECRET_KEY=
HERMES_LANGFUSE_HOST=https://cloud.langfuse.com

# 実機 WiFi（micro-ROS）
ROBOT_WIFI_SSID=
ROBOT_WIFI_PASSWORD=
